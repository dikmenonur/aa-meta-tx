# Sepolia RPC URL - Alchemy veya Infura'dan alın
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# X (Sponsor) cüzdanının private key'i - Sepolia ETH bakiyesi olmalı
PRIVATE_KEY=0xYOUR_SPONSOR_PRIVATE_KEY

# Etherscan API key - contract verification için
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# (Opsiyonel) B cüzdanı - token alacak adres
B_WALLET_ADDRESS=0xRECIPIENT_ADDRESS
